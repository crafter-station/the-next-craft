  "faq": {
    "label": "FAQ",
    "items": [
      {
        "id": "Q01",
        "question": "Who can apply?",
        "answer": "Anyone who builds: devs, designers, PMs. Admission is selective: what you've shipped matters, not your résumé."
      },
      {
        "id": "Q02",
        "question": "How much does it cost?",
        "answer": "Nothing. Getting in is free. Getting in is the hard part."
      },
      {
        "id": "Q03",
        "question": "Can I apply without a team?",
        "answer": "Yes. Team formation happens at the kickoff. Teams of 3 to 5."
      },
      {
        "id": "Q04",
        "question": "What should I bring?",
        "answer": "Laptop, charger and energy. Food, coffee and power are on us."
      },
      {
        "id": "Q05",
        "question": "Can I use AI?",
        "answer": "Obviously. It's 2026. But the code gets written during the 36 hours — no pre-baked projects."
      },
      {
        "id": "Q06",
        "question": "Who owns the IP?",
        "answer": "You do. 100%. We just want to watch you ship."
      },
      {
        "id": "Q07",
        "question": "Is it in-person?",
        "answer": "Yes — in Lima, Bogotá or Guatemala, whichever hub fits you. No remote option: the point is to be there."
      },
      {
        "id": "Q08",
        "question": "How does the jury evaluate?",
        "answer": "Live 3-minute demo. Working product > pretty pitch."
      }
    ]
  },
